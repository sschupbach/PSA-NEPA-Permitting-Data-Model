    </fields>
    <fields>
        <fullName>nepa_project_description__c</fullName>
        <description>Summary of the project&apos;s goals and scope.</description>
        <externalId>false</externalId>
        <inlineHelpText>Summary of the project&apos;s goals and scope.</inlineHelpText>
        <label>Project Description</label>
        <length>32768</length>
        <trackHistory>false</trackHistory>
        <type>LongTextArea</type>
        <visibleLines>5</visibleLines>
    </fields>
    <fields>
        <fullName>nepa_project_id__c</fullName>
        <caseSensitive>false</caseSensitive>
        <description>Unique identification number for the project. Recommend UUID format for global uniqueness.</description>
        <externalId>true</externalId>
        <inlineHelpText>Unique project ID. Recommend UUID format.</inlineHelpText>
        <label>Project Id</label>
        <length>36</length>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Text</type>
        <unique>true</unique>
    </fields>
    <fields>
        <fullName>nepa_project_sector__c</fullName>
        <description>High-level project sector(s). Multiple values may apply; separate with semicolons (e.g., Energy Production and Management; Transportation and Infrastructure).</description>
        <inlineHelpText>High-level project sector(s). Separate multiple values with semicolons.</inlineHelpText>
        <label>Project Sector</label>
        <length>32768</length>
