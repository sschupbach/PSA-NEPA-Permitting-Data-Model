    <fields>
        <fullName>nepa_location_text__c</fullName>
        <description>Text description of location. Where location is more complex than a point or is multi-state/regional, use a text response (WKT or address).</description>
        <inlineHelpText>Text description of location (WKT, address, or region description).</inlineHelpText>
        <externalId>false</externalId>
        <label>Location Text</label>
        <length>255</length>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <!-- Phase 1 Risk Intelligence fields -->
    <fields>
        <fullName>nepa_circuit__c</fullName>
        <description>Federal circuit court jurisdiction for this project's geography. Drives geographic risk weight in litigation risk scoring (9th Circuit and D.C. Circuit carry highest rates in PermitTEC corpus).</description>
        <inlineHelpText>Federal circuit (e.g., 9th, D.C., 4th) for litigation risk geography weighting.</inlineHelpText>
        <externalId>false</externalId>
        <label>Federal Circuit</label>
        <length>50</length>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>nepa_adjacent_statutes__c</fullName>
        <description>Adjacent statutes implicated by this project (e.g., ESA; CWA; NHPA; APA). Multiple values separated by semicolons. Each statute adds compound claim risk per PermitTEC analysis.</description>
        <inlineHelpText>Adjacent statutes (ESA; CWA; NHPA; APA). Each one increases litigation compound claim risk.</inlineHelpText>
        <label>Adjacent Statutes</label>
        <length>32768</length>
        <trackHistory>false</trackHistory>
        <type>LongTextArea</type>
        <visibleLines>2</visibleLines>
    </fields>
    <!-- CE Screening fields (Priority 2) -->
    <fields>
        <fullName>nepa_applicant_naics__c</fullName>
        <description>Six-digit NAICS code of the project sponsor's primary business activity. Used by the CE Screener as a secondary signal to route to the correct agency CE namespace and apply confidence modifiers (NAICS 211/212 → Low confidence). Not a primary CE classifier.</description>
        <inlineHelpText>Applicant NAICS code (6 digits). Used to route CE namespace and flag high-risk industries.</inlineHelpText>
        <externalId>false</externalId>
        <label>Applicant NAICS Code</label>
        <length>6</length>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <!-- Provenance fields (CEQ Standard v1.2 - required on all entities) -->
