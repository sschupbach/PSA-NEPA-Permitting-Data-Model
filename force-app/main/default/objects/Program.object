    <fields>
        <fullName>nepa_project_type__c</fullName>
        <description>Type(s) of project — a sub-type of project sector (e.g., Renewable Energy Production - Solar; Electricity Transmission). Multiple values may apply; separate with semicolons.</description>
        <inlineHelpText>Sub-type(s) of project sector. Separate multiple values with semicolons.</inlineHelpText>
