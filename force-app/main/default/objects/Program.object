<?xml version="1.0" encoding="UTF-8"?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <fields>
        <fullName>nepa_litigation_count__c</fullName>
        <description>Count of litigation cases linked to this NEPA project via nepa_related_project__c on nepa_litigation__c. Updated by Flow when litigation records are created or related. Provides a quick litigation risk signal — EIS projects account for 98%+ of NEPA litigation.</description>
        <inlineHelpText>Number of litigation cases linked to this project.</inlineHelpText>
        <externalId>false</externalId>
        <label>Litigation Case Count</label>
        <precision>6</precision>
        <required>false</required>
        <scale>0</scale>
        <trackHistory>false</trackHistory>
        <type>Number</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>nepa_current_status__c</fullName>
        <description>Current phase of the NEPA, permitting, or other authorization process (may be aggregated from related process status and related milestones or events).</description>
        <inlineHelpText>Current phase: pre-application, in progress, paused, completed, or cancelled.</inlineHelpText>
        <label>Current Status</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value>
                    <fullName>planned</fullName>
                    <default>false</default>
                    <label>planned</label>
                </value>
                <value>
                    <fullName>pre-application</fullName>
                    <default>false</default>
                    <label>pre-application</label>
                </value>
                <value>
                    <fullName>in progress</fullName>
                    <default>false</default>
                    <label>in progress</label>
                </value>
                <value>
                    <fullName>paused</fullName>
                    <default>false</default>
                    <label>paused</label>
                </value>
                <value>
                    <fullName>completed</fullName>
                    <default>false</default>
                    <label>completed</label>
                </value>
                <value>
                    <fullName>cancelled</fullName>
                    <default>false</default>
                    <label>cancelled</label>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>nepa_lead_agency__c</fullName>
        <deleteConstraint>SetNull</deleteConstraint>
        <description>Federal agency that is undertaking the activity or responsible for the decision.</description>
        <inlineHelpText>Federal agency that is undertaking the activity or responsible for the decision.</inlineHelpText>
        <label>Lead Agency</label>
